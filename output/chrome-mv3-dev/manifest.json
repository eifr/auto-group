{
  "manifest_version": 3,
  "name": "Auto Groups",
  "description": "Automatically manage tab groups based on external APIs like GitHub PRs",
  "version": "1.0.0",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://api.github.com/",
    "http://localhost/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "auto-groups@extension.dev",
      "strict_min_version": "138.0"
    }
  },
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Auto Groups",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3000; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3000; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}